<!--pages/login/login.wxml - 登录页面-->
<view class="login-container">
  <view class="logo-section">
    <view class="logo">📚</view>
    <view class="app-name">AI学习助手</view>
    <view class="app-desc">智能辅导 · 轻松学习</view>
  </view>

  <view class="login-form">
    <button class="btn-wechat" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
      <text class="btn-icon">👤</text>
      <text>微信授权登录</text>
    </button>

    <view class="divider">
      <view class="line"></view>
      <text class="divider-text">或</text>
      <view class="line"></view>
    </view>

    <view class="form-group">
      <input class="input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <view class="form-group">
      <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
        <view class="picker-input">
          <text class="{{gradeIndex >= 0 ? 'has-value' : ''}}">{{grades[gradeIndex] || '请选择年级'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <button class="btn-primary" bindtap="onLogin">开始学习</button>
  </view>

  <view class="tips">
    <text class="tips-text">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>