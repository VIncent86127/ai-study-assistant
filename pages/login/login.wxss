/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1528 0%, var(--bg-primary) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.app-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.login-form {
  width: 100%;
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 48rpx 32rpx;
}

.btn-wechat {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
  color: var(--gold-primary);
  border: 2rpx solid var(--gold-primary);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.btn-wechat::after {
  border: none;
}

.btn-icon {
  margin-right: 16rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--gold-dark) 50%, transparent 100%);
}

.divider-text {
  padding: 0 24rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.input, .picker-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-secondary);
  border: 1rpx solid var(--border-gold);
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input::placeholder {
  color: var(--text-muted);
}

.picker-input text {
  color: var(--text-muted);
}

.picker-input text.has-value {
  color: var(--gold-primary);
}

.picker-arrow {
  font-size: 20rpx;
  color: var(--gold-dark);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, var(--gold-dark) 0%, var(--gold-primary) 100%);
  color: var(--bg-primary);
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin-top: 16rpx;
}

.btn-primary::after {
  border: none;
}

.tips {
  margin-top: 48rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-muted);
}