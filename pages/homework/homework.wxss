/* pages/homework/homework.wxss */

.container {
  padding-bottom: 40rpx;
  background-color: var(--bg-primary);
}

.banner {
  background: linear-gradient(180deg, #1a1528 0%, var(--bg-primary) 100%);
  padding: 40rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-gold);
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--gold-primary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.upload-area {
  margin: 24rpx 20rpx;
  background: var(--bg-card);
  border: 2rpx dashed var(--border-gold);
  border-radius: 12rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--gold-primary);
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.reupload-btn {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--gold-primary);
  padding: 16rpx 40rpx;
  border: 1rpx solid var(--gold-dark);
  border-radius: 8rpx;
  display: inline-block;
}

.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 0 20rpx 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.subject-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.subject-tag {
  padding: 12rpx 24rpx;
  background: var(--bg-secondary);
  border: 1rpx solid var(--border-gold);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.subject-tag.active {
  background: var(--gold-primary);
  border-color: var(--gold-primary);
  color: var(--bg-primary);
}

.result-section {
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-gold);
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 26rpx;
  color: var(--text-muted);
}

.result-value {
  font-size: 26rpx;
  color: var(--gold-primary);
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--gold-dark) 50%, transparent 100%);
  margin: 20rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 12rpx;
}

.solution-content, .answer-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.history-list {

}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-gold);
}

.history-item:last-child {
  border-bottom: none;
}

.history-subject {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-secondary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--gold-primary);
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
}

.history-title {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.history-time {
  font-size: 24rpx;
  color: var(--text-muted);
}

.history-arrow {
  color: var(--gold-dark);
}

.empty-state {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
}