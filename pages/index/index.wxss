/* pages/index/index.wxss */

.container {
  padding: 0 0 60rpx 0;
  background-color: var(--bg-primary);
}

/* 横幅 */
.banner {
  background: linear-gradient(180deg, #1a1528 0%, var(--bg-primary) 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  border-bottom: 2rpx solid var(--border-gold);
}

.banner-title {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--gold-primary);
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(201, 162, 39, 0.3);
}

.banner-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 24rpx 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--gold-dark) 0%, var(--gold-primary) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--bg-primary);
  font-weight: bold;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 8rpx;
}

.user-grade {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.study-stats {
  display: flex;
  text-align: center;
}

.study-stats .stats-item {
  padding: 0 20rpx;
}

.study-stats .stats-item:first-child {
  border-right: 1rpx solid var(--border-gold);
}

.study-stats .stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--gold-primary);
}

.study-stats .stats-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* 登录提示 */
.login-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 40rpx;
  margin: 24rpx 20rpx;
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.tip-text {
  font-size: 28rpx;
  color: var(--gold-primary);
  letter-spacing: 2rpx;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  background: var(--bg-card);
  margin: 0 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border-gold);
}

.entry-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  border-right: 1rpx solid var(--border-gold);
}

.entry-item:last-child {
  border-right: none;
}

.entry-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.entry-text {
  font-size: 24rpx;
  color: var(--gold-primary);
  letter-spacing: 2rpx;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 24rpx 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

/* 学科网格 */
.subject-grid {
  display: flex;
  flex-wrap: wrap;
}

.subject-item {
  width: 33.33%;
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-gold);
  border-right: 1rpx solid var(--border-gold);
}

.subject-item:nth-child(3n) {
  border-right: none;
}

.subject-item:nth-child(n+7) {
  border-bottom: none;
}

.subject-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.subject-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 推荐列表 */
.recommend-list {

}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-gold);
}

.recommend-item:last-child {
  border-bottom: none;
}

.recommend-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.recommend-content {
  flex: 1;
}

.recommend-title {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.recommend-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.recommend-arrow {
  color: var(--gold-dark);
  font-size: 24rpx;
}

/* 学习统计网格 */
.stats-grid {

}

.stats-row {
  display: flex;
  border-bottom: 1rpx solid var(--border-gold);
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-cell {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-right: 1rpx solid var(--border-gold);
}

.stats-cell:last-child {
  border-right: none;
}

.stats-cell .stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 8rpx;
}

.stats-cell .stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
}