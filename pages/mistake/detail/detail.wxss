.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 卡片通用样式 */
.info-card,
.question-card,
.answer-card,
.knowledge-card,
.vocab-card,
.notes-card,
.review-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.subject-tag {
  background-color: #e8f4ff;
  color: #007aff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-pending {
  background-color: #fff3e0;
  color: #ff9800;
}

.status-mastered {
  background-color: #e8f5e9;
  color: #4caf50;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* 题目和答案 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.question-text,
.answer-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.answer-text {
  color: #4caf50;
  font-weight: 500;
}

/* 知识点 */
.knowledge-list,
.vocab-list,
.notes-list,
.review-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.knowledge-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.knowledge-type {
  font-size: 22rpx;
  color: #fff;
  background-color: #007aff;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.knowledge-content {
  font-size: 28rpx;
  color: #333;
}

/* 生僻词 */
.vocab-item {
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.vocab-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.vocab-word {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.vocab-phonetic {
  font-size: 24rpx;
  color: #666;
  margin-left: 15rpx;
}

.vocab-meaning {
  font-size: 26rpx;
  color: #555;
  display: block;
}

.vocab-example {
  font-size: 24rpx;
  color: #888;
  font-style: italic;
  margin-top: 10rpx;
  display: block;
}

/* 备注 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  color: #007aff;
  font-size: 26rpx;
}

.note-item {
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.note-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.note-type {
  font-size: 22rpx;
  color: #007aff;
}

.note-time {
  font-size: 22rpx;
  color: #999;
}

.note-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.voice-duration {
  font-size: 22rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.empty-notes {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 复习记录 */
.review-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.review-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.result-correct {
  background-color: #4caf50;
}

.result-partial {
  background-color: #ff9800;
}

.result-wrong {
  background-color: #f44336;
}

.review-date {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.review-result {
  font-size: 24rpx;
  color: #333;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.action-btn {
  flex: 1;
  margin: 0 10rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.review-btn {
  background-color: #007aff;
  color: #fff;
}

.edit-btn {
  background-color: #f5f5f5;
  color: #333;
}

.delete-btn {
  background-color: #fff;
  color: #f44336;
  border: 1rpx solid #f44336;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.modal-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.modal-btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.modal-btn.primary {
  background-color: #007aff;
  color: #fff;
}

/* 生成类似题目弹窗 */
.generate-modal-content {
  width: 90%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background-color: #f8f9fa;
  font-size: 32rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 0 15rpx;
}

.model-selector {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.model-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.model-buttons {
  display: flex;
  gap: 15rpx;
}

.model-btn {
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.model-btn.active {
  background-color: #007aff;
  color: #fff;
}

.generate-result {
  padding: 30rpx;
}

.generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #666;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.generated-content {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.generated-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.model-badge {
  background-color: #007aff;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.generated-label {
  font-size: 26rpx;
  color: #333;
}

.generated-question {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 15rpx;
  background-color: #fff;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.generated-answer {
  font-size: 26rpx;
  color: #4caf50;
  padding: 15rpx;
  background-color: #e8f5e9;
  border-radius: 8rpx;
}

.answer-label {
  color: #666;
}

.generated-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.gen-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 15rpx;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 8rpx;
}

.gen-btn.primary {
  background-color: #007aff;
  color: #fff;
}

.generate-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  color: #999;
}

.start-generate-btn {
  margin-top: 30rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx 50rpx;
  border-radius: 8rpx;
}

/* 知识点板块 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.generate-btn {
  display: flex;
  align-items: center;
  background-color: #fff3e0;
  color: #ff9800;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.generate-icon {
  margin-right: 8rpx;
}

.empty-knowledge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  color: #999;
}

.add-knowledge-btn {
  color: #007aff;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.knowledge-tag {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.knowledge-tag.phrase {
  background-color: #e3f2fd;
  color: #1976d2;
}

.knowledge-tag.pattern {
  background-color: #fce4ec;
  color: #c2185b;
}

.knowledge-tag.grammar {
  background-color: #f3e5f5;
  color: #7b1fa2;
}