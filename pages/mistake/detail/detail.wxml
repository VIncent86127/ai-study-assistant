<view class="container">
  <!-- 基本信息 -->
  <view class="info-card">
    <view class="card-header">
      <view class="subject-tag">{{mistake.subject_name}}</view>
      <view class="status-tag status-{{mistake.status}}">
        {{mistake.status === 'pending' ? '待复习' : '已掌握'}}
      </view>
    </view>
    <view class="meta-row">
      <text class="meta-item" wx:if="{{mistake.grade_name}}">{{mistake.grade_name}}</text>
      <text class="meta-item" wx:if="{{mistake.chapter_name}}">{{mistake.chapter_name}}</text>
      <text class="meta-item" wx:if="{{mistake.difficulty}}">{{mistake.difficulty}}</text>
    </view>
  </view>

  <!-- 题目内容 -->
  <view class="question-card">
    <view class="section-title">题目</view>
    <view class="question-text">{{mistake.question_text}}</view>
  </view>

  <!-- 正确答案 -->
  <view class="answer-card">
    <view class="section-title">正确答案</view>
    <view class="answer-text">{{mistake.correct_answer || '暂无'}}</view>
  </view>

  <!-- 知识点 -->
  <view class="knowledge-card" wx:if="{{knowledgePoints.length > 0}}">
    <view class="section-title">关联知识点</view>
    <view class="knowledge-list">
      <view class="knowledge-item" wx:for="{{knowledgePoints}}" wx:key="id" bindtap="goToKnowledge" data-item="{{item}}">
        <view class="knowledge-type">
          {{item.knowledge_type === 'phrase' ? '短语' : item.knowledge_type === 'pattern' ? '句型' : '语法'}}
        </view>
        <text class="knowledge-content">{{item.knowledge_content}}</text>
      </view>
    </view>
  </view>

  <!-- 生僻词解析 -->
  <view class="vocab-card" wx:if="{{vocabulary.length > 0}}">
    <view class="section-title">生僻词解析</view>
    <view class="vocab-list">
      <view class="vocab-item" wx:for="{{vocabulary}}" wx:key="id">
        <view class="vocab-header">
          <text class="vocab-word">{{item.word}}</text>
          <text class="vocab-phonetic">{{item.phonetic}}</text>
        </view>
        <text class="vocab-meaning">{{item.meaning || '暂无解释'}}</text>
        <text class="vocab-example" wx:if="{{item.example_usage}}">例: {{item.example_usage}}</text>
      </view>
    </view>
  </view>

  <!-- 用户备注 -->
  <view class="notes-card">
    <view class="section-header">
      <text class="section-title">我的思路/备注</text>
      <text class="add-btn" bindtap="addNote">+ 添加</text>
    </view>
    <view class="notes-list" wx:if="{{notes.length > 0}}">
      <view class="note-item" wx:for="{{notes}}" wx:key="id">
        <view class="note-header">
          <text class="note-type">{{item.note_type === 'text' ? '文字' : '语音'}}</text>
          <text class="note-time">{{item.created_at}}</text>
        </view>
        <text class="note-content">{{item.content}}</text>
        <text class="voice-duration" wx:if="{{item.voice_duration}}">{{item.voice_duration}}秒</text>
      </view>
    </view>
    <view class="empty-notes" wx:else>
      <text>暂无备注，点击上方添加</text>
    </view>
  </view>

  <!-- 复习记录 -->
  <view class="review-card" wx:if="{{reviewHistory.length > 0}}">
    <view class="section-title">复习记录</view>
    <view class="review-list">
      <view class="review-item" wx:for="{{reviewHistory}}" wx:key="id">
        <view class="review-dot result-{{item.result}}"></view>
        <text class="review-date">{{item.review_date}}</text>
        <text class="review-result">{{item.result === 'correct' ? '正确' : item.result === 'partial' ? '部分正确' : '错误'}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="action-btn review-btn" bindtap="startReview">开始复习</button>
    <button class="action-btn edit-btn" bindtap="editMistake">编辑</button>
    <button class="action-btn delete-btn" bindtap="deleteMistake">删除</button>
  </view>
</view>

<!-- 添加备注弹窗 -->
<view class="modal-mask" wx:if="{{showNoteModal}}" bindtap="hideNoteModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">添加备注</view>
    <textarea class="modal-textarea" 
              value="{{newNoteContent}}" 
              bindinput="onNewNoteInput"
              placeholder="请输入备注内容..." />
    <view class="modal-actions">
      <button class="modal-btn" bindtap="hideNoteModal">取消</button>
      <button class="modal-btn primary" bindtap="submitNote">确定</button>
    </view>
  </view>
</view>