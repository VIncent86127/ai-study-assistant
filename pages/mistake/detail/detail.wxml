<view class="container">
  <!-- 基本信息 -->
  <view class="info-card">
    <view class="card-header">
      <view class="subject-tag">{{mistake.subject_name}}</view>
      <view class="status-tag status-{{mistake.status}}">
        {{mistake.status === 'pending' ? '待复习' : '已掌握'}}
      </view>
    </view>
    <view class="meta-row">
      <text class="meta-item" wx:if="{{mistake.grade_name}}">{{mistake.grade_name}}</text>
      <text class="meta-item" wx:if="{{mistake.chapter_name}}">{{mistake.chapter_name}}</text>
      <text class="meta-item" wx:if="{{mistake.difficulty}}">{{mistake.difficulty}}星</text>
    </view>
  </view>

  <!-- 题目内容 -->
  <view class="question-card">
    <view class="section-title">题目</view>
    <view class="question-text">{{mistake.question_text}}</view>
  </view>

  <!-- 正确答案 -->
  <view class="answer-card">
    <view class="section-title">正确答案</view>
    <view class="answer-text">{{mistake.correct_answer || '暂无'}}</view>
  </view>

  <!-- 知识点 -->
  <view class="knowledge-card">
    <view class="section-header">
      <text class="section-title">涉及知识点</text>
      <view class="generate-btn" bindtap="generateSimilarQuestion">
        <text class="generate-icon">💡</text>
        <text>生成类似题目</text>
      </view>
    </view>
    <view class="knowledge-list" wx:if="{{knowledgePoints.length > 0}}">
      <view class="knowledge-item" wx:for="{{knowledgePoints}}" wx:key="knowledge_id">
        <view class="knowledge-header" bindtap="toggleKnowledge" data-index="{{index}}">
          <view class="knowledge-tag {{item.knowledge_type}}">
            {{item.knowledge_type === 'phrase' ? '短语' : item.knowledge_type === 'pattern' ? '句型' : '语法'}}
          </view>
          <text class="knowledge-content">{{item.knowledge_content}}</text>
          <text class="knowledge-arrow {{item.expanded ? 'expanded' : ''}}">▼</text>
        </view>
        <view class="knowledge-explanation" wx:if="{{item.expanded && item.explanation}}">
          <text>{{item.explanation}}</text>
        </view>
      </view>
    </view>
    <view class="empty-knowledge" wx:else>
      <text>暂无关联知识点</text>
      <text class="add-knowledge-btn" bindtap="analyzeAgain">重新分析</text>
    </view>
  </view>

  <!-- 生僻词解析 -->
  <view class="vocab-card" wx:if="{{vocabulary.length > 0}}">
    <view class="section-title">生僻词解析</view>
    <view class="vocab-list">
      <view class="vocab-item" wx:for="{{vocabulary}}" wx:key="id">
        <view class="vocab-header">
          <text class="vocab-word">{{item.word}}</text>
          <text class="vocab-phonetic">{{item.phonetic}}</text>
        </view>
        <text class="vocab-meaning">{{item.meaning || '暂无解释'}}</text>
        <text class="vocab-example" wx:if="{{item.example_usage}}">例: {{item.example_usage}}</text>
      </view>
    </view>
  </view>

  <!-- 用户备注 -->
  <view class="notes-card">
    <view class="section-header">
      <text class="section-title">我的思路/备注</text>
      <text class="add-btn" bindtap="addNote">+ 添加</text>
    </view>
    <view class="notes-list" wx:if="{{notes.length > 0}}">
      <view class="note-item" wx:for="{{notes}}" wx:key="id">
        <view class="note-header">
          <text class="note-type">{{item.note_type === 'text' ? '文字' : '语音'}}</text>
          <text class="note-time">{{item.created_at}}</text>
        </view>
        <text class="note-content">{{item.content}}</text>
        <text class="voice-duration" wx:if="{{item.voice_duration}}">{{item.voice_duration}}秒</text>
      </view>
    </view>
    <view class="empty-notes" wx:else>
      <text>暂无备注，点击上方添加</text>
    </view>
  </view>

  <!-- 复习记录 -->
  <view class="review-card" wx:if="{{reviewHistory.length > 0}}">
    <view class="section-title">复习记录</view>
    <view class="review-list">
      <view class="review-item" wx:for="{{reviewHistory}}" wx:key="id">
        <view class="review-dot result-{{item.result}}"></view>
        <text class="review-date">{{item.review_date}}</text>
        <text class="review-result">{{item.result === 'correct' ? '正确' : item.result === 'partial' ? '部分正确' : '错误'}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="action-btn review-btn" bindtap="startReview">开始复习</button>
    <button class="action-btn edit-btn" bindtap="editMistake">编辑</button>
    <button class="action-btn delete-btn" bindtap="deleteMistake">删除</button>
  </view>
</view>

<!-- 添加备注弹窗 -->
<view class="modal-mask" wx:if="{{showNoteModal}}" bindtap="hideNoteModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">添加备注</view>
    <textarea class="modal-textarea" 
              value="{{newNoteContent}}" 
              bindinput="onNewNoteInput"
              placeholder="请输入备注内容..." />
    <view class="modal-actions">
      <button class="modal-btn" bindtap="hideNoteModal">取消</button>
      <button class="modal-btn primary" bindtap="submitNote">确定</button>
    </view>
  </view>
</view>

<!-- AI生成类似题目弹窗 -->
<view class="modal-mask" wx:if="{{showGenerateModal}}" bindtap="hideGenerateModal">
  <view class="generate-modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text>📝 练习类似题目</text>
      <text class="close-btn" bindtap="hideGenerateModal">×</text>
    </view>
    
    <!-- 生成状态 -->
    <view wx:if="{{generating}}" class="generating">
      <text class="loading-icon">⏳</text>
      <text>正在生成练习题...</text>
    </view>
    
    <!-- 两道题目展示 -->
    <view wx:else class="questions-container">
      <!-- DeepSeek题目 -->
      <view class="question-card" wx:if="{{deepseekQuestion}}">
        <view class="question-header">
          <text class="model-badge deepseek">DeepSeek V4</text>
        </view>
        <view class="question-content">{{deepseekQuestion}}</view>
        <view class="action-buttons">
          <button class="do-btn" bindtap="doQuestion" data-model="deepseek">开始做题</button>
        </view>
      </view>
      
      <!-- GLM题目 -->
      <view class="question-card" wx:if="{{glmQuestion}}">
        <view class="question-header">
          <text class="model-badge glm">GLM</text>
        </view>
        <view class="question-content">{{glmQuestion}}</view>
        <view class="action-buttons">
          <button class="do-btn" bindtap="doQuestion" data-model="glm">开始做题</button>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 做题答题弹窗 -->
<view class="modal-mask" wx:if="{{showDoQuestionModal}}" bindtap="hideDoQuestionModal">
  <view class="do-question-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text>✍️ 做题练习</text>
      <text class="close-btn" bindtap="hideDoQuestionModal">×</text>
    </view>
    
    <!-- 题目 -->
    <view class="current-question">
      <view class="model-badge {{currentDoingModel}}">{{currentDoingModel === 'deepseek' ? 'DeepSeek V4' : 'GLM'}}</view>
      <view class="question-text">{{currentQuestion}}</view>
    </view>
    
    <!-- 用户输入答案 -->
    <view class="answer-input-section">
      <text class="input-label">你的答案：</text>
      <textarea class="answer-input" 
                 value="{{userAnswer}}" 
                 bindinput="onUserAnswerInput"
                 placeholder="请输入你的答案..." />
    </view>
    
    <!-- 查看答案按钮 -->
    <view class="check-answer-btn" wx:if="{{!showAnswer}}" bindtap="checkAnswer">
      查看正确答案
    </view>
    
    <!-- 答案展示 -->
    <view class="correct-answer-section" wx:if="{{showAnswer}}">
      <text class="correct-label">正确答案：</text>
      <text class="correct-text">{{currentCorrectAnswer}}</text>
    </view>
    
    <!-- 判断是否理解 -->
    <view class="understand-section" wx:if="{{showAnswer}}">
      <text class="understand-label">你觉得这道题，理解了吗？</text>
      <view class="understand-buttons">
        <view class="understand-btn yes" bindtap="markUnderstood">✓ 理解了</view>
        <view class="understand-btn no" bindtap="markNotUnderstood">✗ 还没理解</view>
      </view>
    </view>
  </view>
</view>

<!-- 复习结果弹窗 -->
<view class="modal-mask" wx:if="{{showResultModal}}" bindtap="hideResultModal">
  <view class="result-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text>📊 复习记录</text>
    </view>
    
    <view class="result-content">
      <view class="result-item">
        <text class="result-label">复习时间：</text>
        <text class="result-value">{{reviewTime}}</text>
      </view>
      <view class="result-item">
        <text class="result-label">这是第</text>
        <text class="result-value highlight">{{reviewCount}}</text>
        <text class="result-label">次复习</text>
      </view>
      <view class="result-item">
        <text class="result-label">同类题掌握情况：</text>
        <text class="result-value {{mastered ? 'success' : 'warning'}}">{{mastered ? '已掌握' : '继续复习'}}</text>
      </view>
    </view>
    
    <button class="close-result-btn" bindtap="hideResultModal">继续学习</button>
  </view>
</view>