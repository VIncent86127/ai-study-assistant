.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 拍照区域 */
.camera-section {
  margin-bottom: 20rpx;
}

.camera-box {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ddd;
}

.camera-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.camera-text {
  color: #666;
  font-size: 28rpx;
}

.image-preview {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.preview-img {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.image-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.action-btn {
  background-color: #f0f0f0;
  color: #666;
}

/* 结果区域 */
.result-section,
.answer-section,
.note-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.edit-btn {
  color: #007aff;
  font-size: 26rpx;
  font-weight: normal;
}

.question-content,
.answer-content,
.note-input-area {
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 15rpx;
}

.question-textarea,
.answer-textarea,
.note-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  font-size: 28rpx;
  color: #666;
}

.picker-value-fixed {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 500;
}

/* 星级显示 */
.stars-picker {
  display: flex;
  align-items: center;
}

.stars-display {
  color: #ff9500;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  font-weight: bold;
}

.stars-text {
  color: #666;
  font-size: 24rpx;
  margin-left: 10rpx;
}

/* 知识点 */
.knowledge-section,
.vocab-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.knowledge-list,
.vocab-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.knowledge-item {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.knowledge-tag {
  background-color: #007aff;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.knowledge-content {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.knowledge-chapter {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  width: 100%;
}

/* 生僻词 */
.vocab-item {
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.vocab-word {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.word-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.word-phonetic {
  font-size: 24rpx;
  color: #666;
  margin-left: 15rpx;
}

.vocab-meaning {
  font-size: 26rpx;
  color: #555;
}

/* 语音输入 */
.voice-input-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-top: 15rpx;
}

.voice-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 30rpx 0;
}

.submit-btn {
  width: 100%;
  background-color: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  height: 90rpx;
  line-height: 90rpx;
}

.submit-btn[disabled] {
  background-color: #ccc;
}