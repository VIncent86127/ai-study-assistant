<!--pages/chat/chat.wxml - AI问答页面-->
<view class="container">
  <!-- 消息列表 -->
  <scroll-view scroll-y class="message-list" scroll-into-view="{{scrollToView}}">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{index}}">
      <!-- 用户消息 -->
      <view class="message user-message" wx:if="{{item.role === 'user'}}">
        <view class="message-content">{{item.content}}</view>
        <view class="message-avatar">👤</view>
      </view>
      
      <!-- AI回复 -->
      <view class="message ai-message" wx:else>
        <view class="message-avatar">🤖</view>
        <view class="message-content">
          <view class="ai-text">{{item.content}}</view>
          <view class="message-actions" wx:if="{{item.actions}}">
            <view class="action-btn" bindtap="copyText" data-text="{{item.content}}">复制</view>
            <view class="action-btn" bindtap="regenerate" data-index="{{index}}">重新回答</view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 正在输入提示 -->
    <view class="typing-indicator" wx:if="{{isTyping}}">
      <view class="message-avatar">🤖</view>
      <view class="typing-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 学科选择 -->
  <view class="subject-bar">
    <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
      <view class="picker-btn">
        <text class="subject-label">当前学科：</text>
        <text class="subject-value">{{subjects[subjectIndex]}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-box">
      <textarea 
        placeholder="输入你的问题..." 
        placeholder-class="input-placeholder"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        adjust-position="{{true}}"
        maxlength="500"
      />
    </view>
    <view class="send-btn" bindtap="sendMessage">
      <text>发送</text>
    </view>
  </view>

  <!-- 快捷问题 -->
  <view class="quick-questions" wx:if="{{messages.length === 0}}">
    <view class="quick-title">试试这些问题：</view>
    <view class="quick-list">
      <view class="quick-item" wx:for="{{quickQuestions}}" wx:key="*this" bindtap="askQuickQuestion" data-question="{{item}}">
        {{item}}
      </view>
    </view>
  </view>
</view>