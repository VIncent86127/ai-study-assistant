/* pages/subject/subject.wxss */

.container {
  padding-bottom: 40rpx;
  background-color: var(--bg-primary);
}

.banner {
  background: linear-gradient(180deg, #1a1528 0%, var(--bg-primary) 100%);
  padding: 40rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-gold);
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--gold-primary);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 24rpx 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.knowledge-list {

}

.knowledge-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-gold);
}

.knowledge-item:last-child {
  border-bottom: none;
}

.knowledge-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.knowledge-info {
  flex: 1;
}

.knowledge-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.knowledge-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.knowledge-count {
  font-size: 24rpx;
  color: var(--gold-primary);
}

.stats-card {
  display: flex;
  margin: 0 20rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-right: 1rpx solid var(--border-gold);
}

.stats-item:last-child {
  border-right: none;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
}