/* app.wxss - AI学习助手全局样式 */

/* 主题色变量 */
page {
  --bg-primary: #0d0d1a;
  --bg-secondary: #151528;
  --bg-card: #1a1a2e;
  --gold-primary: #c9a227;
  --gold-light: #d4af37;
  --gold-dark: #9a7b1a;
  --text-primary: #f5f5f5;
  --text-secondary: #a0a0a0;
  --text-muted: #666666;
  --border-color: #2a2a40;
  --border-gold: #3d3520;
  --success-color: #4caf50;
  --warning-color: #ff9800;
  --error-color: #f44336;
  
  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 通用容器 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: var(--bg-primary);
}

/* 卡片样式 */
.card {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-gold);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--gold-primary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-card) 100%);
  color: var(--gold-primary);
  border: 2rpx solid var(--gold-primary);
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

.btn-primary:active {
  background: var(--gold-primary);
  color: var(--bg-primary);
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: var(--text-secondary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--gold-dark) 50%, transparent 100%);
  margin: 20rpx 0;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
}

.tag-gold {
  background-color: rgba(201, 162, 39, 0.15);
  border: 1rpx solid var(--gold-dark);
  color: var(--gold-primary);
}

.tag-blue {
  background-color: rgba(33, 150, 243, 0.15);
  border: 1rpx solid #1e88e5;
  color: #42a5f5;
}

.tag-green {
  background-color: rgba(76, 175, 80, 0.15);
  border: 1rpx solid #388e3c;
  color: #66bb6a;
}

/* 隐藏 */
.hidden {
  display: none !important;
}

/* Flex布局辅助 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}